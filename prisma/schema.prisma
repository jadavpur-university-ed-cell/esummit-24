// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

model User{
  email  String @id 
  name   String
  Usertype String?
  college String?
  teams  Team[] @relation("UserTeam")
  isVerified Boolean @default(false)
}

model Team{
  id    String @id 
  name  String 
  users User[] @relation("UserTeam")
  events Event[] @relation("EventTeam")
  isRegistered Boolean @default(false)
}

// register logic is something like this:
// Imagine i make a team with 4 ppl, then I want to register for an event.
// in their dashboard, the can see "my teams " and under there for any event they can see "register" button.
// when they click on register, the team is registered for the event,
// then a notification is sent to everyone in the team, when if everyone accepts
// isRegistered is set to true.
// multiple teams can be made and registered for a user and also the event.
model Event{
  id    String @id
  name  String
  teams Team[] @relation("EventTeam")
}